{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "title": "Abenix — Scaling Ops",
  "uid": "abenix-scaling-ops",
  "version": 1,
  "schemaVersion": 38,
  "timezone": "",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["abenix", "scaling"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Executions (1h) — by pool",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (pool) (rate(abenix_execution_duration_seconds_count[1h]) * 3600)",
        "legendFormat": "{{pool}}",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Queue depth — by pool",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "abenix_queue_depth{pool=~\".+\"}",
        "legendFormat": "{{pool}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency — by pool (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, pool) (rate(abenix_execution_duration_seconds_bucket[5m])))",
        "legendFormat": "p95 {{pool}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rate-limit hits — per (tenant, agent)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (tenant_id, agent_slug) (rate(abenix_rate_limit_hits_total[5m]))",
        "legendFormat": "{{tenant_id}}/{{agent_slug}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Circuit breaker state — by provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(abenix_circuit_breaker_trips_total[10m])", "legendFormat": "trips {{provider}}", "refId": "A" },
        { "expr": "rate(abenix_circuit_breaker_failfast_total[5m])", "legendFormat": "fail-fast {{provider}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Token spend — by tenant (1h)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sort_desc(sum by (tenant_id, provider, model) (rate(abenix_llm_cost_usd_total[1h]) * 3600))",
        "format": "table",
        "instant": true,
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    }
  ]
}
