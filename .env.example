# ── Database ───────────────────────────────────────────────
POSTGRES_USER=abenix
POSTGRES_PASSWORD=abenix
POSTGRES_DB=abenix
DATABASE_URL=postgresql+asyncpg://abenix:abenix@localhost:5432/abenix

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]

# ── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── LLM Providers ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Agent Runtime Mode ────────────────────────────────────
# embedded = run agents inline in API process (default, local dev)
# remote   = delegate to runtime pods via HTTP (production K8s)
RUNTIME_MODE=embedded
RUNTIME_URL=http://localhost:8001

# ── File Storage ─────────────────────────────────────────
# Backend: local (filesystem), s3 (S3-compatible: AWS, MinIO, R2), azure (Blob)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/uploads
# For MinIO (local K8s): STORAGE_BACKEND=s3, STORAGE_S3_ENDPOINT=http://minio:9000
# For AWS S3: STORAGE_BACKEND=s3, STORAGE_S3_BUCKET=your-bucket
# For Azure: STORAGE_BACKEND=azure, STORAGE_AZURE_CONNECTION_STRING=...
STORAGE_S3_BUCKET=abenix-uploads
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_AZURE_CONNECTION_STRING=
STORAGE_AZURE_CONTAINER=abenix-files

EXPORT_DIR=./data/exports

# ── RAG / Vector Store ────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=abenix-knowledge
UPLOAD_DIR=./data/uploads

# ── Knowledge Engine / Neo4j ─────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=abenix
NEO4J_DATABASE=neo4j

# ── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── PgAdmin (optional, use `docker compose --profile tools up`) ─
PGADMIN_EMAIL=admin@abenix.dev
PGADMIN_PASSWORD=admin

# === OracleNet ===
NEXT_PUBLIC_ORACLENET_API_KEY=af_oraclenet_default_key
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
SERPER_API_KEY=
SEARCH_PROVIDER=tavily
FRED_API_KEY=
NEWS_API_KEY=
MEDIASTACK_API_KEY=

# === Energy API's ===
EMBER_API_KEY=
EIA_API_KEY=
FMP_API_KEY=

# === ContractIQ ===
CONTRACTIQ_JWT_SECRET=change-me-in-production
EIA_API_KEY=
ENTSOE_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ZAPIER_NLA_KEY=
DEEPL_API_KEY=

# ── Sandboxed Job Runner ───────────────────────────────────
# The sandboxed_job tool runs one-shot commands in isolated
# containers (kubernetes Job in cluster, docker on host). Both
# vars MUST be set or the tool returns "disabled". Allow-list
# only images the tool may run.
SANDBOXED_JOB_ENABLED=true
SANDBOXED_JOB_ALLOWED_IMAGES=alpine:3.20,busybox:1.36,python:3.12-slim,gcc:13,golang:1.22-alpine,rust:1.80-slim,eclipse-temurin:21-jdk,node:20-alpine,sbtscala/scala-sbt:eclipse-temurin-jammy-21.0.2_13_1.10.0_3.4.2,zenika/kotlin:1.9.24-jdk-jre-alpine-slim,mcr.microsoft.com/dotnet/sdk:8.0,ruby:3.3-alpine

# ── Meeting Representative (LiveKit) ──────────────────────
# The Meeting Representative agent joins meetings via LiveKit. Self-host
# `livekit/livekit-server` or use LiveKit Cloud (https://livekit.io/cloud).
# LIVEKIT_MEET_URL is optional and only used to generate a "Join as
# participant" link in the UI.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_MEET_URL=https://meet.livekit.io

# TTS voice — OpenAI voices: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=alloy

# Voice cloning via ElevenLabs. Without this, the /api/persona/voice/upload
# endpoint is disabled and the bot uses OpenAI's generic voices only.
# The Meeting Representative ALWAYS falls back to OpenAI if the user hasn't
# recorded consent — there's a hard consent gate in meeting_speak.
ELEVENLABS_API_KEY=

# Optional: webhook for defer-to-human notifications (Slack incoming webhook
# is the default format; any JSON POST receiver works)
DEFER_NOTIFY_WEBHOOK_URL=

# Stubs for future providers — leave empty until you've completed the
# Azure tenant / Zoom marketplace review steps documented in README.
TEAMS_GRAPH_TENANT_ID=
TEAMS_GRAPH_CLIENT_ID=
TEAMS_GRAPH_CLIENT_SECRET=
TEAMS_BOT_CERT_PATH=
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=


