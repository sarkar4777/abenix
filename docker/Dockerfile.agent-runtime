FROM python:3.12.8-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

FROM base AS deps
COPY apps/agent-runtime/pyproject.toml ./pyproject.toml
COPY apps/agent-runtime/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir . && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir uvicorn fastapi boto3

FROM base AS runtime
COPY --from=deps /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=deps /usr/local/bin /usr/local/bin
COPY packages/db/ ./packages/db/
COPY apps/agent-runtime/ ./apps/agent-runtime/
WORKDIR /app/apps/agent-runtime

ENV PYTHONPATH="/app/packages/db:/app/apps/agent-runtime"

RUN adduser --system --uid 1001 appuser
USER appuser

EXPOSE 8001
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/health')" || exit 1
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
